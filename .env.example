# ─────────────────────────────────────────────────────────────────────────────
# Infinity Designer Boutique – Environment Variables Template
# Copy this file to ".env" and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Flask environment: development | production
FLASK_ENV=development

# Flask debug (set to False in production)
FLASK_DEBUG=True

# ── Firebase ─────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON key
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Your Firebase project ID (visible in the Firebase console)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Storage bucket  (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# ── Boutique Branding ─────────────────────────────────────────────────────────
BOUTIQUE_NAME=Infinity Designer Boutique

# ── Session ───────────────────────────────────────────────────────────────────
# Session lifetime in seconds  (default 8 hours)
SESSION_LIFETIME_SECONDS=28800

# ── Root Admin Seed (used only by setup_root_admin.py) ───────────────────────
ROOT_ADMIN_FULL_NAME=Owner
ROOT_ADMIN_PHONE=9999999999
ROOT_ADMIN_PIN=0000
