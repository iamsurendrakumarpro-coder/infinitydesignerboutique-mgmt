# ─────────────────────────────────────────────────────────────────────────────
# .env.example – Environment variable template for Infinity Designer Boutique
#
# Copy this file to .env and fill in all required values before running:
#
#   cp .env.example .env
#
# NEVER commit your real .env file to version control.
# The .gitignore must include ".env" to prevent accidental exposure.
# ─────────────────────────────────────────────────────────────────────────────


# ── Flask Core ────────────────────────────────────────────────────────────────
# FLASK_ENV selects the config class: "development" or "production".
FLASK_ENV=development

# Long random secret used to sign session cookies.
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Set to True only in local development; always False in production.
FLASK_DEBUG=True

# Port for the built-in development server (not used by Gunicorn).
PORT=5000


# ── Session ───────────────────────────────────────────────────────────────────
# How long (in seconds) a session remains valid after login.
# Default: 28800 = 8 hours.
SESSION_LIFETIME_SECONDS=28800


# ── Firebase / Firestore ─────────────────────────────────────────────────────
# Path to the Firebase service-account JSON credentials file.
# This file is NOT committed to the repo; keep it outside the project root
# or load from a secrets manager in production.
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Your Firebase project ID (found in the Firebase console → Project settings).
FIREBASE_PROJECT_ID=your-firebase-project-id

# Your Firebase Storage bucket name (e.g. your-project-id.appspot.com).
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com


# ── Application ───────────────────────────────────────────────────────────────
# Display name used in the UI and log headers.
BOUTIQUE_NAME=Infinity Designer Boutique


# ── Logging ───────────────────────────────────────────────────────────────────
# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG in development; INFO or WARNING in production.
LOG_LEVEL=DEBUG


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# In production, set this to your exact frontend domain(s).
# Leave empty in production if the frontend is served by the same Flask process.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Root Admin Seeding (used by setup_root_admin.py only) ────────────────────
# These variables are only consumed by the one-time setup script.
# Remove or leave blank after the root admin has been created.
ROOT_ADMIN_FULL_NAME=Root Admin
ROOT_ADMIN_PHONE=9999999999
ROOT_ADMIN_PIN=0000
