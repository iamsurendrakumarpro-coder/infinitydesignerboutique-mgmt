{% extends "admin/layout.html" %}

{% block page_title %}Dashboard{% endblock %}

{% block page_content %}
<div x-data="adminDashboard()" x-init="loadAll()" x-cloak>

  <!-- ── Mobile Hero Banner ─────────────────────────────────────────── -->
  <div class="mb-4 mobile-hero md:hidden">
    <div class="flex items-center justify-between">
      <div class="min-w-0">
        <p class="text-[10px] font-semibold text-white/60 uppercase tracking-widest">Welcome back</p>
        <h1 class="mt-0.5 text-base font-bold text-white truncate">{{ user.full_name|default("Admin") }}</h1>
        <p class="mt-0.5 text-[11px] text-white/70" x-text="currentDateTime"></p>
      </div>
      <button @click="loadAll()"
              :disabled="refreshing"
              class="flex-shrink-0 flex h-8 w-8 items-center justify-center rounded-lg bg-white/15 text-white active:bg-white/25 transition-colors disabled:opacity-50"
              title="Refresh">
        <svg class="h-3.5 w-3.5" :class="refreshing && 'animate-spin'" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Desktop page header -->
  <div class="page-header-desktop mb-5">
    <div class="flex items-center gap-2">
      <div>
        <h1 class="text-sm font-semibold text-gray-800">{{ user.full_name|default("Admin") }}</h1>
        <p class="text-xs text-gray-400" x-text="currentDateTime"></p>
      </div>
    </div>
    <button @click="loadAll()" :disabled="refreshing"
            class="inline-flex items-center gap-1.5 rounded border border-gray-200 px-2.5 py-1 text-[11px] font-medium text-gray-500 transition-colors hover:bg-gray-50 disabled:opacity-50">
      <svg class="h-3 w-3" :class="refreshing && 'animate-spin'" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182"/>
      </svg>
      Refresh
    </button>
  </div>

  <!-- KPI Section — Single Active Staff Card as CTA -->
  <a href="/admin/staff?status=active" class="mb-6 block cursor-pointer">
    <div class="ent-stat rounded-xl bg-gradient-to-br from-brand-50 to-brand-100/50 p-4 shadow-card ring-1 ring-brand-200 hover:ring-brand-300 transition-all hover:shadow-lg">
      <p class="text-xs font-medium text-brand-600 uppercase tracking-widest">Total Active</p>
      <p class="mt-2 text-3xl font-bold text-brand-700" x-text="stats.totalStaff">-</p>
      <p class="mt-1 text-xs text-brand-600">Staff Members</p>
    </div>
  </a>

  <!-- Charts Section — hidden on mobile + sm, visible md+ (768px and up) -->
  <div class="mb-5 grid gap-4 lg:grid-cols-3 hidden md:grid">
    <!-- Attendance Trend Chart -->
    <div class="lg:col-span-2 ent-card rounded-xl bg-white p-4 shadow-card ring-1 ring-gray-100">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-xs font-semibold text-gray-600">Weekly Attendance Trend</h3>
        <span class="text-[11px] text-gray-400">Last 7 days</span>
      </div>
      <div class="h-44 sm:h-52">
        <canvas id="attendanceChart"></canvas>
      </div>
    </div>

    <!-- Financial Overview Doughnut -->
    <div class="ent-card rounded-xl bg-white p-4 shadow-card ring-1 ring-gray-100">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-xs font-semibold text-gray-600">Financial Overview</h3>
        <span class="text-[11px] text-gray-400">This Month</span>
      </div>
      <div class="h-44 sm:h-52 flex items-center justify-center">
        <canvas id="financialChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Staff by Designation chart — visible md+ only -->
  <div class="mb-6 ent-card rounded-xl bg-white p-4 shadow-card ring-1 ring-gray-100 hidden md:block">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-xs font-semibold text-gray-600">Staff by Designation</h3>
    </div>
    <div class="h-44">
      <canvas id="designationChart"></canvas>
    </div>
  </div>

  <!-- ── Attendance table ───────────────────────────────────────────── -->
  <div class="flex flex-col gap-6">

    <div class="ent-card rounded-xl bg-white shadow-card ring-1 ring-gray-100">
      <div class="flex flex-col gap-2 border-b border-gray-100 px-4 py-3 sm:flex-row sm:items-end sm:justify-between">
        <div class="flex items-center gap-1.5">
          <span class="text-brand-500" x-html="renderIcon('calendar', 'h-4 w-4')"></span>
          <div>
            <h2 class="text-xs font-semibold text-gray-700">Today's Attendance</h2>
            <p class="text-[10px] text-gray-400 mt-0.5" x-text="attendance.length + ' staff checked in'"></p>
          </div>
        </div>
        <button @click="showAttendanceDetails = !showAttendanceDetails"
                class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-[11px] font-medium text-gray-600 transition-all hover:bg-brand-100 hover:text-brand-600">
          <span x-text="showAttendanceDetails ? '−' : '⊕'"></span>
          <span x-text="showAttendanceDetails ? 'Summary' : 'Details'"></span>
        </button>
      </div>

      <div class="px-4 py-3" x-show="!attendanceLoading">
        <div class="grid grid-cols-4 gap-2">
          <div class="rounded-lg bg-green-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-green-700">Present</p>
            <p class="mt-0.5 text-base font-bold text-green-900" x-text="attendance.filter(r => ['in','present','out','completed'].includes((r.status || '').toLowerCase())).length"></p>
          </div>
          <div class="rounded-lg bg-blue-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-blue-700">Working</p>
            <p class="mt-0.5 text-base font-bold text-blue-900" x-text="attendance.filter(r => ['in','present'].includes((r.status || '').toLowerCase())).length"></p>
          </div>
          <div class="rounded-lg bg-gray-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-gray-700">Finished</p>
            <p class="mt-0.5 text-base font-bold text-gray-900" x-text="attendance.filter(r => ['out','completed'].includes((r.status || '').toLowerCase())).length"></p>
          </div>
          <div class="rounded-lg bg-red-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-red-700">Absent</p>
            <p class="mt-0.5 text-base font-bold text-red-900" x-text="attendance.filter(r => (r.status || '').toLowerCase() === 'absent').length"></p>
          </div>
        </div>
      </div>

      <div x-show="attendanceLoading" class="px-5 py-10 text-center">
        <svg class="mx-auto h-8 w-8 animate-spin text-brand-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </div>

      <div x-show="!attendanceLoading && attendance.length === 0" class="px-5 py-8 text-center">
        <p class="text-sm text-gray-400">No attendance data for today</p>
      </div>

      <div x-show="!attendanceLoading && attendance.length > 0 && !showAttendanceDetails" class="px-4 pb-3 text-[11px] text-gray-400">
        Click “Details” to see individual times.
      </div>

      <div x-show="!attendanceLoading && attendance.length > 0 && showAttendanceDetails" class="overflow-x-auto">
        <table class="w-full text-xs table-mobile-cards">
          <thead>
            <tr class="border-b border-gray-100 text-left text-[11px] font-medium uppercase tracking-wider text-gray-400">
              <th class="px-4 py-2">Name</th>
              <th class="px-3 py-2">In</th>
              <th class="px-3 py-2">Out</th>
              <th class="px-3 py-2">Hours</th>
              <th class="px-3 py-2">OT</th>
              <th class="px-3 py-2 text-right">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <template x-for="row in attendance" :key="row.staff_id || row.user_id">
              <tr class="hover:bg-gray-50/50">
                <td class="px-4 py-2" data-label="">
                  <div class="flex items-center gap-2">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-[10px] font-bold text-brand-700"
                         x-text="getInitials(row.staff_name || row.full_name || row.employee_name)"></div>
                    <span class="text-xs font-medium text-gray-800" x-text="row.staff_name || row.full_name || row.employee_name || '-'"></span>
                  </div>
                </td>
                <td class="px-3 py-2 text-gray-500" data-label="In" x-text="formatDateTimeIST(row.punch_in_time) || formatDateTimeIST(row.punch_in) || formatDateTimeIST(row.login_time) || '-'"></td>
                <td class="px-3 py-2 text-gray-500" data-label="Out" x-text="formatDateTimeIST(row.punch_out_time) || formatDateTimeIST(row.punch_out) || '-'"></td>
                <td class="px-3 py-2 text-gray-500" data-label="Hours">
                  <span x-text="row.duration_minutes ? formatDuration(row.duration_minutes) : calculateHours(row.punch_in_time, row.punch_out_time)"></span>
                </td>
                <td class="px-3 py-2 text-gray-500" data-label="OT">
                  <span x-text="calculateOT(row.punch_in_time, row.punch_out_time, row.standard_login_time, row.standard_logout_time)"></span>
                </td>
                <td class="px-3 py-2 text-right" data-label="Status">
                  <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-medium"
                        :class="{
                          'bg-green-100 text-green-700': row.status === 'in' || row.status === 'present',
                          'bg-gray-100 text-gray-500': row.status === 'out' || row.status === 'completed',
                          'bg-red-100 text-red-600': row.status === 'absent',
                        }">
                    <template x-if="row.status === 'in' || row.status === 'present'">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    </template>
                    <template x-if="row.status === 'out' || row.status === 'completed'">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3"/></svg>
                    </template>
                    <template x-if="row.status === 'absent'">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </template>
                    <span x-text="formatStatus(row.status)"></span>
                  </span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

    <div class="ent-card rounded-xl bg-white shadow-card ring-1 ring-gray-100">
      <div class="flex flex-col gap-2 border-b border-gray-100 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-2">
          <span class="text-blue-600" x-html="renderIcon('calendar', 'h-4 w-4')"></span>
          <div>
            <h2 class="text-xs font-semibold text-gray-700">Daily Time Records</h2>
            <p class="mt-0.5 text-[11px] text-gray-400">Each staff's daily login/logout details</p>
          </div>
        </div>
        <button @click="showDailyAttendance = !showDailyAttendance"
                class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-[11px] font-medium text-gray-600 transition-colors hover:bg-gray-200">
          <span x-text="showDailyAttendance ? '−' : '⊕'"></span>
          <span x-text="showDailyAttendance ? 'Summary' : 'Details'"></span>
        </button>
      </div>

      <div x-show="!showDailyAttendance" class="px-4 py-3 text-[11px] text-gray-400">
        <span x-text="attendance.length + ' staff records • '"></span>
        <span x-text="new Date().toLocaleDateString('en-IN', {year: 'numeric', month: 'short', day: 'numeric'})"></span>
      </div>

      <div x-show="showDailyAttendance && attendance.length > 0" class="overflow-x-auto">
        <table class="w-full text-xs table-mobile-cards">
          <thead>
            <tr class="border-b border-gray-100 text-left text-[11px] font-medium uppercase tracking-wider text-gray-400">
              <th class="px-4 py-2">Name</th>
              <th class="px-3 py-2">Login</th>
              <th class="px-3 py-2">Logout</th>
              <th class="px-3 py-2">Hours</th>
              <th class="px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <template x-for="row in attendance" :key="row.staff_id || row.user_id">
              <tr class="hover:bg-gray-50/50">
                <td class="px-4 py-2" data-label="Name">
                  <div class="flex items-center gap-2">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-[10px] font-bold text-brand-700"
                         x-text="getInitials(row.staff_name || row.full_name || row.employee_name)"></div>
                    <span class="text-xs font-medium text-gray-800" x-text="row.staff_name || row.full_name || row.employee_name || '-'"></span>
                  </div>
                </td>
                <td class="px-3 py-2 font-mono text-gray-600" data-label="Login" 
                    x-text="formatDateTimeIST(row.punch_in_time) || formatDateTimeIST(row.punch_in) || formatDateTimeIST(row.login_time) || '—'"></td>
                <td class="px-3 py-2 font-mono text-gray-600" data-label="Logout"
                    x-text="formatDateTimeIST(row.punch_out_time) || formatDateTimeIST(row.punch_out) || '—'"></td>
                <td class="px-3 py-2" data-label="Hours">
                  <template x-if="calculateHoursDifference(row.punch_in_time, row.punch_out_time) !== null">
                    <span class="font-mono font-medium text-gray-800"
                          :class="calculateHoursDifference(row.punch_in_time, row.punch_out_time) >= 8 ? 'text-green-600' : calculateHoursDifference(row.punch_in_time, row.punch_out_time) >= 6 ? 'text-yellow-600' : 'text-red-600'"
                          x-text="calculateHoursDifference(row.punch_in_time, row.punch_out_time).toFixed(2) + 'h'"></span>
                  </template>
                  <template x-if="calculateHoursDifference(row.punch_in_time, row.punch_out_time) === null">
                    <span class="font-mono text-gray-400">—</span>
                  </template>
                </td>
                <td class="px-3 py-2" data-label="Status">
                  <span :class="{
                    'bg-green-100 text-green-700': ['in', 'present', 'out', 'completed'].includes((row.status || '').toLowerCase()),
                    'bg-red-100 text-red-600': (row.status || '').toLowerCase() === 'absent',
                    'bg-gray-100 text-gray-500': !row.status
                  }" class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-medium">
                    <span x-text="formatStatus(row.status) || 'Pending'"></span>
                  </span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>

      <div x-show="showDailyAttendance && attendance.length === 0" class="px-4 py-6 text-center">
        <p class="text-xs text-gray-400">No attendance data for today</p>
      </div>
    </div>

    <div class="ent-card rounded-xl bg-white shadow-card ring-1 ring-gray-100">
      <div class="flex flex-col gap-2 border-b border-gray-100 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-2">
          <span class="text-green-600" x-html="renderIcon('banknotes', 'h-4 w-4')"></span>
          <h2 class="text-xs font-semibold text-gray-700">Staff Pay Summary</h2>
          <div class="flex items-center rounded-md bg-gray-100 p-0.5">
            <button @click="setPayoutRange('this_week')"
                    class="admin-tab-btn px-2 py-1 text-[11px] transition-all"
                    :class="payoutRange === 'this_week' ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'">
              This Week
            </button>
            <button @click="setPayoutRange('last_week')"
                    class="admin-tab-btn px-2 py-1 text-[11px] transition-all"
                    :class="payoutRange === 'last_week' ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'">
              Last Week
            </button>
            <button @click="setPayoutRange('this_month')"
                    class="admin-tab-btn px-2 py-1 text-[11px] transition-all"
                    :class="payoutRange === 'this_month' ? 'bg-white text-gray-800 shadow-sm' : 'text-gray-500 hover:text-gray-700'">
              Month
            </button>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="rounded-full bg-green-50 px-2 py-0.5 text-[11px] font-medium text-green-700"
                x-text="'₹' + Number(payoutTotal || 0).toLocaleString('en-IN')"></span>
          <button @click="showPayoutDetails = !showPayoutDetails"
                  class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-[11px] font-medium text-gray-600 transition-colors hover:bg-gray-200">
            <span x-text="showPayoutDetails ? '−' : '⊕'"></span>
            <span x-text="showPayoutDetails ? 'Summary' : 'Details'"></span>
          </button>
          <a href="/admin/settlements"
             class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-[11px] font-medium text-gray-600 transition-colors hover:bg-gray-200">
            <span x-html="renderIcon('arrow-top-right', 'h-3 w-3')"></span>
            <span>View All</span>
          </a>
        </div>
      </div>

      <div class="px-4 pt-2 text-[11px] text-gray-400" x-show="payoutPeriodLabel">
        <span x-text="payoutPeriodLabel"></span>
      </div>

      <div class="px-4 py-3" x-show="!payoutLoading">
        <div class="grid grid-cols-3 gap-2">
          <div class="rounded-lg bg-gray-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-gray-700">Staff</p>
            <p class="mt-0.5 text-base font-bold text-gray-900" x-text="payoutRows.length"></p>
          </div>
          <div class="rounded-lg bg-green-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-green-700">Total Pay</p>
            <p class="mt-0.5 text-base font-bold text-green-900" x-text="'₹' + Number(payoutTotal || 0).toLocaleString('en-IN')"></p>
          </div>
          <div class="rounded-lg bg-blue-50 px-2.5 py-2">
            <p class="text-[10px] font-medium text-blue-700">Average</p>
            <p class="mt-0.5 text-base font-bold text-blue-900" x-text="payoutRows.length ? '₹' + Math.round(payoutTotal / payoutRows.length).toLocaleString('en-IN') : '₹0'"></p>
          </div>
        </div>
      </div>

      <div x-show="payoutLoading" class="px-4 py-8 text-center">
        <svg class="mx-auto h-6 w-6 animate-spin text-brand-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </div>

      <div x-show="!payoutLoading && payoutRows.length === 0" class="px-4 py-8 text-center">
        <p class="text-xs text-gray-400">No pay data for this period</p>
      </div>

      <div x-show="!payoutLoading && payoutRows.length > 0 && !showPayoutDetails" class="px-4 pb-3 text-[11px] text-gray-400">
        Click "Details" to see staff-wise pay breakup.
      </div>

      <div x-show="!payoutLoading && payoutRows.length > 0 && showPayoutDetails" class="overflow-x-auto">
        <table class="w-full text-xs table-mobile-cards">
          <thead>
            <tr class="border-b border-gray-100 text-left text-[11px] font-medium uppercase tracking-wider text-gray-400">
              <th class="px-4 py-2">Name</th>
              <th class="px-3 py-2">Period</th>
              <th class="px-3 py-2 text-right">Salary</th>
              <th class="px-3 py-2 text-right">OT</th>
              <th class="px-3 py-2 text-right">Cuts</th>
              <th class="px-3 py-2 text-right">Net Pay</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <template x-for="row in payoutRows" :key="row.id || row.settlement_id || row.user_id">
              <tr class="hover:bg-gray-50/50">
                <td class="px-4 py-2" data-label="">
                  <div class="flex items-center gap-2">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-100 text-[10px] font-bold text-green-700"
                         x-text="getInitials(row.staff_name || row.full_name || 'Staff')"></div>
                    <span class="text-xs font-medium text-gray-800" x-text="row.staff_name || row.full_name || 'Staff'"></span>
                  </div>
                </td>
                <td class="px-3 py-2 text-gray-500" data-label="Period">
                  <span x-text="formatDate(row.week_start || row.period_start)"></span>–<span x-text="formatDate(row.week_end || row.period_end)"></span>
                </td>
                <td class="px-3 py-2 text-right text-gray-600" data-label="Salary">
                  ₹<span x-text="Number(row.base_salary ?? row.weekly_salary ?? 0).toLocaleString('en-IN')"></span>
                </td>
                <td class="px-3 py-2 text-right text-green-600" data-label="OT">
                  +₹<span x-text="Number(row.overtime_pay ?? row.overtime ?? 0).toLocaleString('en-IN')"></span>
                </td>
                <td class="px-3 py-2 text-right text-red-500" data-label="Cuts">
                  -₹<span x-text="Number((row.advances ?? row.personal_advances ?? 0) + (row.expenses ?? row.shop_expenses ?? 0)).toLocaleString('en-IN')"></span>
                </td>
                <td class="px-3 py-2 text-right" data-label="Net Pay">
                  <span class="inline-flex rounded-full bg-green-100 px-2 py-0.5 text-[11px] font-semibold text-green-700">
                    ₹<span x-text="Number(row.net_payable ?? row.net_pay ?? 0).toLocaleString('en-IN')"></span>
                  </span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block page_scripts %}
<script>
  function getInitials(name) {
    if (!name || name === 'Unknown Staff') return '?';
    return name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
  }

  function formatStatus(status) {
    if (!status) return '-';
    return status.charAt(0).toUpperCase() + status.slice(1);
  }

  function formatIST(utcString) {
    if (!utcString) return '';
    const d = new Date(utcString);
    return d.toLocaleTimeString('en-IN', {
      hour: '2-digit',
      minute: '2-digit',
      timeZone: 'Asia/Kolkata'
    });
  }

  function formatDateTimeIST(utcString) {
    if (!utcString) return '';
    const d = new Date(utcString);
    return d.toLocaleString('en-IN', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
      timeZone: 'Asia/Kolkata'
    });
  }

  function formatDate(dateString) {
    if (!dateString) return '-';
    const d = new Date(dateString);
    if (isNaN(d.getTime())) return '-';
    return d.toLocaleDateString('en-IN', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      timeZone: 'Asia/Kolkata',
    });
  }

  function calculateHours(punchIn, punchOut) {
    if (!punchIn || !punchOut) return '-';
    try {
      const inTime = new Date(punchIn);
      const outTime = new Date(punchOut);
      const diffMs = outTime - inTime;
      if (diffMs <= 0) return '-';
      const hours = Math.floor(diffMs / (1000 * 60 * 60));
      const minutes = Math.floor((diffMs / (1000 * 60)) % 60);
      return `${hours}h ${minutes}m`;
    } catch {
      return '-';
    }
  }

  function calculateOT(punchIn, punchOut, stdIn, stdOut) {
    if (!punchIn || !punchOut || !stdIn || !stdOut) return '-';
    try {
      const inTime = new Date(punchIn);
      const outTime = new Date(punchOut);
      const today = new Date();
      const stdInParts = stdIn.split(':');
      const stdOutParts = stdOut.split(':');
      const stdInTime = new Date(today.getFullYear(), today.getMonth(), today.getDate(), parseInt(stdInParts[0]), parseInt(stdInParts[1]));
      const stdOutTime = new Date(today.getFullYear(), today.getMonth(), today.getDate(), parseInt(stdOutParts[0]), parseInt(stdOutParts[1]));
      const workedMinutes = (outTime - inTime) / (1000 * 60);
      const stdMinutes = (stdOutTime - stdInTime) / (1000 * 60);
      const extraMinutes = workedMinutes - stdMinutes;
      if (isNaN(extraMinutes) || extraMinutes <= 0) return '-';
      const hours = Math.floor(extraMinutes / 60);
      const minutes = Math.floor(extraMinutes % 60);
      return `${hours}h ${minutes}m`;
    } catch {
      return '-';
    }
  }

  function formatDuration(minutes) {
    if (!minutes || isNaN(minutes)) return '-';
    const hrs = Math.floor(minutes / 60);
    const mins = Math.floor(minutes % 60);
    return `${hrs}h ${mins}m`;
  }

  function calculateHoursDifference(punchIn, punchOut) {
    if (!punchIn || !punchOut) return null;
    try {
      const inTime = new Date(punchIn);
      const outTime = new Date(punchOut);
      const diffMs = outTime - inTime;
      if (diffMs <= 0) return null;
      return diffMs / (1000 * 60 * 60); // return hours as decimal
    } catch {
      return null;
    }
  }

  function adminDashboard() {
    return {
      refreshing: false,
      attendanceLoading: true,
      analyticsLoading: true,
      payoutLoading: true,
      currentDateTime: '',
      stats: {
        totalStaff: '-',
        todayPresent: '-',
        pendingApprovals: '-',
        pendingOvertime: '-',
      },
      attendance: [],
      showAttendanceDetails: false,
      showDailyAttendance: false,
      payoutRows: [],
      payoutTotal: 0,
      payoutPeriodLabel: '',
      payoutRange: 'this_week',
      showPayoutDetails: false,
      charts: {
        attendance: null,
        financial: null,
        designation: null,
      },

      async loadAll() {
        this.refreshing = true;
        this.updateDateTime();
        await Promise.all([
          this.fetchDashboard(),
          this.fetchAnalytics(),
          this.fetchPayoutSnapshot(),
        ]);
        this.refreshing = false;
      },

      updateDateTime() {
        const now = new Date();
        const opts = {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
          hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata',
        };
        this.currentDateTime = now.toLocaleString('en-IN', opts) + ' IST';
      },

      async fetchDashboard() {
        this.attendanceLoading = true;
        try {
          const res = await fetch('/api/v1/dashboard/summary', { credentials: 'include' });
          if (res.ok) {
            const data = await res.json();
            const summary = data.summary || {};
            this.stats.totalStaff       = summary.total_active_staff ?? summary.total_staff ?? summary.active_staff ?? 0;
            this.stats.todayPresent     = summary.punched_in ?? summary.today_present ?? summary.present_today ?? 0;
            this.stats.pendingApprovals = summary.pending_financial_requests ?? summary.pending_approvals ?? summary.pending_financial ?? 0;
            this.stats.pendingOvertime  = summary.pending_overtime_approvals ?? summary.pending_overtime ?? 0;
            this.attendance = summary.today_attendance || summary.attendance || [];
          }
        } catch (e) {
          console.error('Dashboard fetch error:', e);
        } finally {
          this.attendanceLoading = false;
        }
      },

      async fetchAnalytics() {
        this.analyticsLoading = true;
        try {
          const res = await fetch('/api/v1/dashboard/analytics', { credentials: 'include' });
          if (res.ok) {
            const data = await res.json();
            const analytics = data.analytics || {};
            this.renderCharts(analytics);
          }
        } catch (e) {
          console.error('Analytics fetch error:', e);
        } finally {
          this.analyticsLoading = false;
        }
      },

      getCurrentWeekRange(offsetWeeks = 0) {
        const today = new Date();
        const day = today.getDay();
        const monday = new Date(today);
        monday.setDate(today.getDate() - ((day === 0 ? 7 : day) - 1));
        if (offsetWeeks !== 0) {
          monday.setDate(monday.getDate() + (offsetWeeks * 7));
        }
        const sunday = new Date(monday);
        sunday.setDate(monday.getDate() + 6);

        const toYmd = (d) => {
          const yyyy = d.getFullYear();
          const mm = String(d.getMonth() + 1).padStart(2, '0');
          const dd = String(d.getDate()).padStart(2, '0');
          return `${yyyy}-${mm}-${dd}`;
        };

        return { weekStart: toYmd(monday), weekEnd: toYmd(sunday) };
      },

      getCurrentMonthRange() {
        const now = new Date();
        const start = new Date(now.getFullYear(), now.getMonth(), 1);
        const end = new Date(now.getFullYear(), now.getMonth() + 1, 0);

        const toYmd = (d) => {
          const yyyy = d.getFullYear();
          const mm = String(d.getMonth() + 1).padStart(2, '0');
          const dd = String(d.getDate()).padStart(2, '0');
          return `${yyyy}-${mm}-${dd}`;
        };

        return { weekStart: toYmd(start), weekEnd: toYmd(end) };
      },

      getPayoutDateRange() {
        if (this.payoutRange === 'last_week') return this.getCurrentWeekRange(-1);
        if (this.payoutRange === 'this_month') return this.getCurrentMonthRange();
        return this.getCurrentWeekRange(0);
      },

      async setPayoutRange(range) {
        if (this.payoutRange === range) return;
        this.payoutRange = range;
        await this.fetchPayoutSnapshot();
      },

      async fetchPayoutSnapshot() {
        this.payoutLoading = true;
        try {
          const { weekStart, weekEnd } = this.getPayoutDateRange();
          const res = await fetch(`/api/v1/settlements?week_start=${weekStart}&week_end=${weekEnd}`, { credentials: 'include' });
          if (res.ok) {
            const data = await res.json();
            const settlements = data.settlements || [];

            // Filter to only active staff
            this.payoutRows = settlements.filter(s => 
              (s.status === 'active' || s.staff_status === 'active') || 
              (!s.status && !s.staff_status) // If status not specified, include
            );
            this.payoutTotal = this.payoutRows.reduce((sum, s) => sum + Number(s.net_payable ?? s.net_pay ?? 0), 0);
            this.payoutPeriodLabel = `${formatDate(weekStart)} - ${formatDate(weekEnd)}`;
          } else {
            this.payoutRows = [];
            this.payoutTotal = 0;
            this.payoutPeriodLabel = '';
          }
        } catch (e) {
          console.error('Payout snapshot fetch error:', e);
          this.payoutRows = [];
          this.payoutTotal = 0;
          this.payoutPeriodLabel = '';
        } finally {
          this.payoutLoading = false;
        }
      },

      renderCharts(analytics) {
        // Destroy existing charts
        if (this.charts.attendance) this.charts.attendance.destroy();
        if (this.charts.financial) this.charts.financial.destroy();
        if (this.charts.designation) this.charts.designation.destroy();

        const brandColor = '#4f46e5';
        const brandColorLight = 'rgba(79, 70, 229, 0.1)';

        // Attendance Trend Line Chart
        const attendanceCtx = document.getElementById('attendanceChart');
        if (attendanceCtx && analytics.attendance_trend) {
          const trend = analytics.attendance_trend;
          this.charts.attendance = new Chart(attendanceCtx, {
            type: 'line',
            data: {
              labels: trend.map(d => d.day),
              datasets: [
                {
                  label: 'Present',
                  data: trend.map(d => d.present),
                  borderColor: '#10b981',
                  backgroundColor: 'rgba(16, 185, 129, 0.1)',
                  fill: true,
                  tension: 0.4,
                },
                {
                  label: 'Absent',
                  data: trend.map(d => d.absent),
                  borderColor: '#ef4444',
                  backgroundColor: 'rgba(239, 68, 68, 0.1)',
                  fill: true,
                  tension: 0.4,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: {
                  position: 'top',
                  labels: { usePointStyle: true, padding: 20 },
                },
              },
              scales: {
                y: {
                  beginAtZero: true,
                  ticks: { stepSize: 1 },
                  grid: { color: 'rgba(0,0,0,0.05)' },
                },
                x: {
                  grid: { display: false },
                },
              },
            },
          });
        }

        // Financial Overview Doughnut Chart
        const financialCtx = document.getElementById('financialChart');
        if (financialCtx && analytics.financial_overview) {
          const fin = analytics.financial_overview;
          this.charts.financial = new Chart(financialCtx, {
            type: 'doughnut',
            data: {
              labels: ['Expenses', 'Advances', 'Pending'],
              datasets: [{
                data: [fin.approved_expenses, fin.approved_advances, fin.pending_count * 100],
                backgroundColor: ['#f59e0b', '#3b82f6', '#6b7280'],
                borderWidth: 0,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              cutout: '65%',
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: { usePointStyle: true, padding: 15 },
                },
              },
            },
          });
        }

        // Staff Distribution Bar Chart
        const designationCtx = document.getElementById('designationChart');
        if (designationCtx && analytics.staff_distribution) {
          const dist = analytics.staff_distribution;
          this.charts.designation = new Chart(designationCtx, {
            type: 'bar',
            data: {
              labels: dist.map(d => d.designation),
              datasets: [{
                label: 'Staff Count',
                data: dist.map(d => d.count),
                backgroundColor: brandColor,
                borderRadius: 6,
                barThickness: 24,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              indexAxis: 'y',
              plugins: {
                legend: { display: false },
              },
              scales: {
                x: {
                  beginAtZero: true,
                  ticks: { stepSize: 1 },
                  grid: { color: 'rgba(0,0,0,0.05)' },
                },
                y: {
                  grid: { display: false },
                },
              },
            },
          });
        }
      },
    };
  }
</script>
{% endblock %}
